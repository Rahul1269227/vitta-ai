#
# Transaction-AI style environment template for Sentinel-Fi
#

# Database Configuration
POSTGRES_DB=txn_user
POSTGRES_USER=txn_user
POSTGRES_PASSWORD=txn_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://txn_user:txn_password@localhost:5432/txn_user
POSTGRES_URL=postgresql+psycopg://txn_user:txn_password@postgres:5432/txn_user

# Optional parity vars from transaction-ai
REDIS_URL=redis://localhost:6379/0
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# App Configuration
OPENAI_API_KEY=
APP_NAME=Sentinel-Fi
ENV=dev
LOG_LEVEL=INFO
LLM_MODEL=gpt-4o-mini

# Routing / Classification
EMBEDDING_MODEL=BAAI/bge-m3
ENABLE_LOCAL_EMBEDDINGS=true
FAST_MODE_ENABLED=true
SLM_ESCALATION_THRESHOLD=0.72
AUTO_ACCEPT_THRESHOLD=0.90
REVIEW_THRESHOLD=0.80
REVIEW_THRESHOLD_DEFAULT=0.80
REVIEW_THRESHOLD_HIGH_RISK=0.85

# Taxonomy
TAXONOMY_BASE_PATH=data/taxonomy_base.yaml
TAXONOMY_OVERRIDES_PATH=data/taxonomy_overrides.yaml

# ML
ENABLE_ML_CLASSIFIER=true
ML_MODEL_PATH=models/transaction_ml_classifier.joblib
ML_MIN_CONFIDENCE=0.72
ML_METRICS_PATH=output/reports/ml_training_metrics.json
ML_FEEDBACK_DATASET_PATH=data/feedback/corrections.jsonl
ML_FEEDBACK_RETRAIN_THRESHOLD=25
ML_FEEDBACK_MIN_ROWS=10
ML_RETRAIN_COOLDOWN_MINUTES=60
ML_DRIFT_WINDOW=1000
ML_DRIFT_Z_WARNING=2.5
ML_DRIFT_Z_CRITICAL=4.0
ML_DRIFT_PSI_WARNING=0.2
ML_DRIFT_PSI_CRITICAL=0.35
ML_BUSINESS_RATE_WARNING=0.15
ML_BUSINESS_RATE_CRITICAL=0.25

# Security
PII_HASH_SALT=replace-this-in-prod
ENABLE_API_KEY_AUTH=false
API_KEYS_CSV=
ADMIN_API_KEYS_CSV=
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_BACKEND=auto
CORS_ALLOW_ORIGINS_CSV=*
UPLOAD_MAX_BYTES=10485760
LOCAL_INGESTION_ROOTS_CSV=data/uploads,data
ENABLE_PDF_OCR_FALLBACK=true
PDF_OCR_LANG=en
PROMETHEUS_ENABLED=true
OTEL_ENABLED=false
OTEL_SERVICE_NAME=sentinelfi-api
OTEL_EXPORTER_OTLP_ENDPOINT=

# Cleanup live execution
CLEANUP_LIVE_MODE=false
CLEANUP_WEBHOOK_TIMEOUT_SECONDS=15
CLEANUP_WEBHOOK_MAX_ATTEMPTS=4
CLEANUP_WEBHOOK_RETRY_BASE_SECONDS=0.5
CLEANUP_WEBHOOK_RETRY_MAX_SECONDS=8.0
CLEANUP_WEBHOOK_HMAC_SECRET=
CLEANUP_LEDGER_WEBHOOK_URL=
CLEANUP_LEDGER_WEBHOOK_HMAC_SECRET=
CLEANUP_INVOICE_WEBHOOK_URL=
CLEANUP_INVOICE_WEBHOOK_HMAC_SECRET=
CLEANUP_GST_WEBHOOK_URL=
CLEANUP_GST_WEBHOOK_HMAC_SECRET=
CLEANUP_EMAIL_SMTP_HOST=
CLEANUP_EMAIL_SMTP_PORT=587
CLEANUP_EMAIL_SMTP_USERNAME=
CLEANUP_EMAIL_SMTP_PASSWORD=
CLEANUP_EMAIL_SMTP_USE_TLS=true
CLEANUP_EMAIL_SMTP_USE_SSL=false
CLEANUP_EMAIL_FROM=
CLEANUP_EMAIL_TO_CSV=

# Leak detection thresholds
LEAK_DUPLICATE_MIN_AMOUNT=300
LEAK_DUPLICATE_AMOUNT_TOLERANCE=0.05
LEAK_ZOMBIE_MIN_AMOUNT=199
LEAK_PRICE_HIKE_MIN_AMOUNT=100
LEAK_PRICE_HIKE_JUMP_THRESHOLD=0.25
LEAK_FREE_TRIAL_LOOKBACK_DAYS=60
LEAK_FREE_TRIAL_LOW_AMOUNT_ABS=50
LEAK_FREE_TRIAL_LOW_AMOUNT_RATIO=0.10

# Alerts / notifications
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_SECONDS=10
ALERT_WEBHOOK_MAX_ATTEMPTS=3
ALERT_WEBHOOK_RETRY_BASE_SECONDS=0.5
ALERT_WEBHOOK_RETRY_MAX_SECONDS=6.0
ALERT_WEBHOOK_HMAC_SECRET=

# Integrations
STRIPE_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Workers
AUDIT_JOB_WORKERS=2
